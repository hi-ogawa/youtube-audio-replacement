{
  "manifest_version": 3,
  "name": "YouTube Audio Replacement",
  "version": "0.0.1",
  "description": "Replace a YouTube video's audio with a synchronized local audio file.",
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://*.googlevideo.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "world": "MAIN",
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.youtube.com/embed/"],
      "js": ["acquisition.js"],
      "world": "MAIN",
      "all_frames": true,
      "run_at": "document_start"
    },
    {
      "matches": ["https://www.youtube.com/embed/"],
      "js": ["relay.js"],
      "all_frames": true,
      "run_at": "document_start"
    },
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["opener.js"],
      "run_at": "document_start"
    }
  ]
}
